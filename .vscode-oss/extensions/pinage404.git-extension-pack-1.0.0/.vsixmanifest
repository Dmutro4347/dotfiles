  <Metadata>
    <Identity Language="en-US" Id="git-extension-pack" Version="1.0.0" Publisher="pinage404"  />
    <DisplayName>Git Extension Pack</DisplayName>
    <Description xml:space="preserve">Opinionated extension pack to improve Git usage (Git hosting agnostic)</Description>
    <Tags>git,__web_extension</Tags>
    <Categories>Extension Packs</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Badges></Badges>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Code.Engine" Value="^1.59.0" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionDependencies" Value="" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionPack" Value="bee.git-temporal-vscode,eamodio.gitlens,felipecaputo.git-project-manager,letmaik.git-tree-compare,mhutchie.git-graph,reduckted.vscode-gitweblinks,trentrand.git-rebase-shortcuts" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionKind" Value="workspace,web" />
      <Property Id="Microsoft.VisualStudio.Code.LocalizedLanguages" Value="" />
      
        <Property Id="Microsoft.VisualStudio.Services.Links.Source" Value="https://gitlab.com/pinage404/pinage404-vscode-extension-packs.git" />
        <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://gitlab.com/pinage404/pinage404-vscode-extension-packs.git" />
        
          <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://gitlab.com/pinage404/pinage404-vscode-extension-packs.git" />
        
      
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://gitlab.com/pinage404/pinage404-vscode-extension-packs/-/issues" />
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://gitlab.com/pinage404/pinage404-vscode-extension-packs/-/tree/main/packages/git" />
